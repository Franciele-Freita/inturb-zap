{
  "name": "inturb-zap-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend NestJS para agendamento de corridas via WhatsApp.",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "tunnel": "ngrok start api site app-mobile --config \"%LocalAppData%\\ngrok\\ngrok.yml,ngrok.yml\"",
    "tunnel:all": "ngrok start --all --config \"%LocalAppData%\\ngrok\\ngrok.yml,ngrok.yml\"",
    "tunnel:api": "ngrok start api --config \"%LocalAppData%\\ngrok\\ngrok.yml,ngrok.yml\"",
    "tunnel:site": "ngrok start site --config \"%LocalAppData%\\ngrok\\ngrok.yml,ngrok.yml\"",
    "tunnel:passenger": "ngrok start passenger-app --config \"%LocalAppData%\\ngrok\\ngrok.yml,ngrok.yml\"",
    "tunnel:driver": "ngrok start driver-app --config \"%LocalAppData%\\ngrok\\ngrok.yml,ngrok.yml\"",
    "tunnel:mobile": "ngrok start app-mobile --config \"%LocalAppData%\\ngrok\\ngrok.yml,ngrok.yml\"",
    "tunnel:mobile-stack": "ngrok start api app-mobile --config \"%LocalAppData%\\ngrok\\ngrok.yml,ngrok.yml\"",
    "build": "nest build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "webpush:keys": "node scripts/generate-web-push-keys.cjs",
    "cbo:import": "ts-node --transpile-only scripts/import-cbo.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@prisma/client": "^6.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.2",
    "@nestjs/testing": "^11.1.6",
    "@types/node": "^22.13.10",
    "prisma": "^6.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
