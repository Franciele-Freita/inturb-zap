generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
  DRIVER
}

enum UserGender {
  FEMALE
  MALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum RideStatus {
  NEW
  QUOTED
  PREBOOKED
  ACCEPTED
  COMPLETED
  REJECTED
  EXPIRED
  CANCELLED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  AUDIO
  IMAGE
  TEMPLATE
}

enum DriverDecisionType {
  ACCEPT
  REJECT
}

enum DriverRideStage {
  SCHEDULED
  EN_ROUTE_PICKUP
  ARRIVED
  IN_PROGRESS
  COMPLETED
}

model User {
  id           String        @id @default(cuid())
  role         UserRole
  cpf          String?
  phone        String?       @unique
  email        String?
  passwordHash String?
  isActive     Boolean       @default(true)
  name         String
  birthDate    DateTime?
  gender       UserGender?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  driver   Driver?
  sessions UserSession[]
  createdTimeEntries    TimeEntry[]             @relation("TimeEntryCreatedBy")
  updatedTimeEntries    TimeEntry[]             @relation("TimeEntryUpdatedBy")
  requestedTimeAdjustments TimeAdjustmentRequest[] @relation("TimeAdjustmentRequestedBy")
  updatedTimeAdjustments   TimeAdjustmentRequest[] @relation("TimeAdjustmentUpdatedBy")
  reviewedTimeAdjustments TimeAdjustmentRequest[] @relation("TimeAdjustmentReviewedBy")
  createdFinancialManualTransactions FinancialManualTransaction[] @relation("FinancialManualTransactionCreatedBy")
  updatedFinancialManualTransactions FinancialManualTransaction[] @relation("FinancialManualTransactionUpdatedBy")
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Customer {
  id                 String   @id @default(cuid())
  phone              String   @unique
  name               String
  hasReducedMobility Boolean?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  favoriteAddresses CustomerFavoriteAddress[]
}

model CustomerFavoriteAddress {
  id         String   @id @default(cuid())
  customerId String
  label      String
  labelKey   String
  address    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, labelKey])
  @@index([customerId])
}

model TripType {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String?
  surchargeAmount Decimal  @default(0) @db.Decimal(10, 2)
  isActive        Boolean  @default(true)
  isDefault       Boolean  @default(false)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PricingConfig {
  id                 String   @id @default(cuid())
  currency           String   @default("BRL")
  baseFare           Decimal  @default(6) @db.Decimal(10, 2)
  distanceRatePerKm  Decimal  @default(2.1) @db.Decimal(10, 2)
  timeRatePerMinute  Decimal  @default(0.35) @db.Decimal(10, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum DriverCompensationModel {
  PERCENT
  FLAT
  DAILY
  SHIFT
  SALARY
  INTERMITTENT
  CUSTOM
}

enum RemunerationTemplateWorkerType {
  DRIVER
}

enum BenefitType {
  FIXED
  PERCENTAGE
  VARIABLE
  INFORMATIVE
}

enum BenefitFrequency {
  MONTHLY
  DAILY
  PER_USE
  PER_TRIP
  ONE_TIME
}

enum BenefitApplicationMode {
  PER_EMPLOYEE
  PER_DAY_WORKED
  PER_TRIP
}

enum WorkProfileContractType {
  CLT
  CLT_INTERMITENTE
  MEI
  PJ
  AUTONOMO
}

enum HolidayScopeType {
  NATIONAL
  STATE
  CITY
}

enum TimeEntryKind {
  IN
  OUT
  BREAK_START
  BREAK_END
}

enum TimeEntrySource {
  APP
  WEB
  ADMIN
  IMPORT
}

enum TimeEntryStatus {
  REGISTERED
  ADJUSTED
  CANCELLED
}

enum TimeEntryIssueCode {
  UNEXPECTED_FIRST_ENTRY
  INVALID_SEQUENCE
  MISSING_BREAK_END
  MISSING_OUT
}

enum TimeEntryIssueSeverity {
  WARNING
  ERROR
}

enum TimeEntryIssueStatus {
  OPEN
  RESOLVED
  AUTO_RESOLVED
}

enum TimeAdjustmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TimeSheetPeriodStatus {
  OPEN
  CLOSED
}

enum TimeSheetPeriodEventAction {
  CLOSE
  REOPEN
}

enum FinancialTransactionCategoryType {
  REVENUE
  EXPENSE
  BOTH
}

enum FinancialManualTransactionType {
  EARNING
  EXPENSE
  PAYMENT
  ADJUSTMENT
}

enum FinancialManualTransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum DsrWeeklyRestDay {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum DriverLeavePeriodType {
  VACATION
  LEAVE
  SUSPENSION
}

enum DriverType {
  AGREGADO
  FROTA
}

enum FleetAssignmentMode {
  FIXED
  FLEX
}

enum DriverOperationalStatus {
  ACTIVE
  INACTIVE
  LEAVE
  SUSPENDED
}

enum FleetVehicleStatus {
  AVAILABLE
  ALLOCATED
  MAINTENANCE
  INACTIVE
}

enum FleetVehicleAssignmentValidationMethod {
  QR_CODE
  PLATE
  ADMIN
}

enum FleetMaintenanceTaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum FleetMaintenanceTaskType {
  GENERAL
  PREVENTIVE
  CORRECTIVE
  ALIGNMENT
  BALANCING
  OIL_CHANGE
  TIRE
  INSPECTION
  CLEANING
  BODYWORK
}

enum FleetMaintenanceTaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FleetChecklistRoutine {
  START_OF_DAY
  END_OF_DAY
}

enum FleetChecklistInputType {
  BOOLEAN
  ODOMETER
  TEXT
  SELECT
  NUMBER
  PHOTO
}

enum FleetChecklistTaskActionType {
  NONE
  REQUIRE_PHOTO
  OPEN_MAINTENANCE
  OPEN_SUPPORT_TICKET
  REQUIRE_NOTE
  REQUIRE_NUMBER
}

model DriverCompensationConfig {
  id           String                  @id @default(cuid())
  model        DriverCompensationModel @default(PERCENT)
  defaultValue Decimal                 @default(0) @db.Decimal(10, 2)
  isActive     Boolean                 @default(false)
  notes        String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
}

model RemunerationTemplate {
  id              String                         @id @default(cuid())
  name            String
  description     String?
  workerType      RemunerationTemplateWorkerType @default(DRIVER)
  contractProfile String?
  isActive        Boolean                        @default(true)
  settings        Json
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  @@index([workerType, isActive, createdAt])
}

model OvertimeTemplate {
  id           String   @id @default(cuid())
  name         String
  description  String?
  isActive     Boolean  @default(true)
  workProfiles Json?
  settings     Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive, updatedAt])
}

model BenefitTemplate {
  id                 String                 @id @default(cuid())
  name               String
  description        String?
  isActive           Boolean                @default(true)
  type               BenefitType
  frequency          BenefitFrequency
  applicationMode    BenefitApplicationMode
  valueConfig        Json
  deductFromSalary   Boolean                @default(false)
  incursCharges      Boolean                @default(false)
  isMandatory        Boolean                @default(false)
  editableInContract Boolean                @default(true)
  workProfiles       Json?
  contractProfiles   Json?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([isActive, type, updatedAt])
}

model Cargo {
  id                 String                @id @default(cuid())
  name               String
  description        String?
  department         String
  level              String
  levels             Json
  cboCode            String?
  cboTitle           String?
  unhealthyAllowance String                @default("NONE")
  hazardousAllowance String                @default("NONE")
  isActive           Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  workProfiles WorkProfileTemplate[]

  @@unique([name, department])
  @@index([isActive, name])
}

model WorkProfileTemplate {
  id                         String                  @id @default(cuid())
  name                       String
  description                String?
  isActive                   Boolean                 @default(true)
  cargoId                    String?
  cargoName                  String
  cargoLevel                 String?
  contractType               WorkProfileContractType
  journeyTemplateId          String?
  journeyTemplateName        String?
  journeySummary             String?
  remuneration               Json
  usesOvertime               Boolean                 @default(true)
  overtimeTemplateId         String?
  overtimeTemplateName       String?
  overtimeSummary            String?
  usesNightPolicy            Boolean                 @default(false)
  nightTemplateId            String?
  nightTemplateName          String?
  nightSummary               String?
  holidayScopeType           HolidayScopeType?
  holidayStateCode           String?
  holidayCityCode            String?
  holidaySummary             String?
  toleranceMarkingMinutes    Int?
  toleranceDailyMaxMinutes   Int?
  benefits                   Json?
  allowContractEditing       Boolean                 @default(true)
  allowJourneyCustomization  Boolean                 @default(true)
  allowBenefitsCustomization Boolean                 @default(true)
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt

  cargo Cargo? @relation(fields: [cargoId], references: [id], onDelete: SetNull)

  @@index([cargoId])
  @@index([isActive, updatedAt])
}

model WorkJourneyTemplate {
  id                 String   @id @default(cuid())
  name               String
  description        String?
  isActive           Boolean  @default(true)
  type               String
  allowedDays        Json
  breakType          String
  breakDurationMinutes Int?
  maxHoursPerDay     Decimal  @db.Decimal(5, 2)
  notes              String?
  fixedConfig        Json?
  flexibleConfig     Json?
  intermittentConfig Json?
  dsrEnabled         Boolean  @default(false)
  dsrWeeklyRestDay   DsrWeeklyRestDay?
  dsrReflectOvertime Boolean  @default(true)
  dsrReflectNight    Boolean  @default(true)
  dsrLoseOnUnjustifiedAbsence Boolean @default(false)
  dsrDescription     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([isActive, updatedAt])
  @@index([type, isActive])
}

model Holiday {
  id          String           @id @default(cuid())
  date        DateTime
  name        String
  scopeType   HolidayScopeType @default(NATIONAL)
  stateCode   String?
  cityCode    String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([date, isActive])
  @@index([scopeType, stateCode, cityCode, isActive])
  @@unique([date, scopeType, stateCode, cityCode, name])
}

model CboOccupation {
  id          String   @id @default(cuid())
  code        String   @unique
  title       String
  description String?
  source      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, title])
  @@index([title])
}

model CompanyProfileConfig {
  id                         String   @id @default(cuid())
  legalName                  String   @default("Inturb Plataforma de Mobilidade LTDA")
  tradeName                  String   @default("Inturb")
  cnpj                       String?
  phone                      String?
  email                      String   @default("operacao@inturb.local")
  website                    String?
  zipCode                    String?
  street                     String?
  number                     String?
  neighborhood               String?
  city                       String?
  state                      String?
  legalRepresentativeName    String?
  legalRepresentativeCpf     String?
  legalRepresentativeRole    String?
  contractSignatureCity      String?
  geofenceEnabled            Boolean  @default(false)
  geofenceBaseLatitude       Decimal? @db.Decimal(9, 6)
  geofenceBaseLongitude      Decimal? @db.Decimal(9, 6)
  geofenceRadiusMeters       Int      @default(150)
  toleranceMarkingMinutes    Int      @default(5)
  toleranceDailyMaxMinutes   Int      @default(10)
  employmentLinkageConfigs   CompanyEmploymentLinkage[]
  financialCategories        FinancialTransactionCategory[]
  financialManualTransactions FinancialManualTransaction[]
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model FinancialTransactionCategory {
  id               String                           @id @default(cuid())
  companyProfileId String
  code             String
  name             String
  type             FinancialTransactionCategoryType @default(EXPENSE)
  color            String?
  icon             String?
  isActive         Boolean                          @default(true)
  sortOrder        Int                              @default(100)
  createdAt        DateTime                         @default(now())
  updatedAt        DateTime                         @updatedAt

  companyProfile CompanyProfileConfig @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)

  @@unique([companyProfileId, code])
  @@index([companyProfileId, isActive, sortOrder, name])
}

model FinancialManualTransaction {
  id                            String                         @id @default(cuid())
  companyProfileId              String
  driverId                      String?
  type                          FinancialManualTransactionType
  status                        FinancialManualTransactionStatus @default(COMPLETED)
  categoryCode                  String
  description                   String
  amount                        Decimal                        @db.Decimal(10, 2)
  occurredAt                    DateTime
  referenceId                   String?
  notes                         String?
  metadata                      Json?
  isReversal                    Boolean                        @default(false)
  reversalOfManualTransactionId String?
  createdByUserId               String?
  updatedByUserId               String?
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt

  companyProfile CompanyProfileConfig @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  driver         Driver?              @relation(fields: [driverId], references: [id], onDelete: SetNull)
  createdBy      User?                @relation("FinancialManualTransactionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy      User?                @relation("FinancialManualTransactionUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([companyProfileId, occurredAt])
  @@index([companyProfileId, driverId, occurredAt])
  @@index([companyProfileId, categoryCode, occurredAt])
}

model CompanyEmploymentLinkage {
  id               String                  @id @default(cuid())
  companyProfileId String
  key              WorkProfileContractType
  label            String
  description      String?
  isActive         Boolean                 @default(true)
  sortOrder        Int                     @default(1)
  settings         Json?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  companyProfile CompanyProfileConfig @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  rules          CompanyEmploymentLinkageRule[]

  @@unique([companyProfileId, key])
  @@index([companyProfileId, sortOrder, key])
}

model CompanyEmploymentLinkageRule {
  id                       String   @id @default(cuid())
  companyEmploymentLinkageId String
  code                     String
  name                     String
  description              String?
  isActive                 Boolean  @default(true)
  priority                 Int      @default(100)
  settings                 Json
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  companyEmploymentLinkage CompanyEmploymentLinkage @relation(fields: [companyEmploymentLinkageId], references: [id], onDelete: Cascade)

  @@unique([companyEmploymentLinkageId, code])
  @@index([companyEmploymentLinkageId, isActive, priority])
}

enum PricingRuleScheduleType {
  WEEKLY_WINDOW
  DATE_RANGE
}

enum PricingRuleAdjustmentType {
  FLAT
  PERCENT
}

model PricingRule {
  id              String                    @id @default(cuid())
  name            String
  description     String?
  scheduleType    PricingRuleScheduleType
  adjustmentType  PricingRuleAdjustmentType @default(FLAT)
  adjustmentValue Decimal                   @default(0) @db.Decimal(10, 2)
  isActive        Boolean                   @default(true)
  priority        Int                       @default(100)
  daysOfWeek      String?
  startMinutes    Int?
  endMinutes      Int?
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
}

model ConversationSession {
  id            String   @id @default(cuid())
  channel       String   @default("WEB_SIMULATOR")
  customerPhone String?
  currentStep   String
  latestRideId  String?
  state         Json
  messages      Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerPhone, updatedAt])
}

model Driver {
  id                    String                  @id @default(cuid())
  userId                String                  @unique
  vehicle               String?
  isActive              Boolean                 @default(true)
  photoUrl              String?
  bloodType             String?
  emergencyContacts     Json?
  address               Json?
  driverLicense         Json?
  toxicology            Json?
  complianceHistory     Json?
  contractProfile       String?
  journey               Json?
  contract              Json?
  authorizedCategories  Json?
  driverType            DriverType              @default(AGREGADO)
  fleetAssignmentMode   FleetAssignmentMode?
  defaultFleetVehicleId String?
  operationalStatus     DriverOperationalStatus @default(ACTIVE)
  operationalNotes      String?
  useGlobalCompensation Boolean                 @default(true)
  compensationModel     DriverCompensationModel?
  compensationValue     Decimal?                @db.Decimal(10, 2)
  compensationNotes     String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  user          User                 @relation(fields: [userId], references: [id])
  assignedRides Ride[]               @relation("RideAssignedDriver")
  decisions     DriverRideDecision[]
  pushSubscriptions DriverPushSubscription[]
  expoPushTokens DriverExpoPushToken[]
  financialManualTransactions FinancialManualTransaction[]
  leavePeriods  DriverLeavePeriod[]
  vehicles      Vehicle[]
  timeEntries   TimeEntry[]
  timeEntryIssues TimeEntryIssue[]
  timeAdjustments TimeAdjustmentRequest[]
  timesheetDays TimeSheetDay[]
  timesheetPeriods TimeSheetPeriod[]
  fleetAssignments FleetVehicleAssignment[]
  defaultFleetVehicle FleetVehicle? @relation("DriverDefaultFleetVehicle", fields: [defaultFleetVehicleId], references: [id])

  @@index([defaultFleetVehicleId])
}

model TimeEntry {
  id         String          @id @default(cuid())
  driverId   String
  createdByUserId String?
  updatedByUserId String?
  occurredAt DateTime
  kind       TimeEntryKind
  source     TimeEntrySource @default(APP)
  status     TimeEntryStatus @default(REGISTERED)
  timezone   String?
  deviceMeta Json?
  geo        Json?
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  createdByUser User? @relation("TimeEntryCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("TimeEntryUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  adjustments TimeAdjustmentRequest[]

  @@index([driverId, occurredAt])
  @@index([occurredAt])
  @@index([kind, occurredAt])
  @@index([status, occurredAt])
  @@index([createdByUserId])
  @@index([updatedByUserId])
}

model TimeAdjustmentRequest {
  id                String               @id @default(cuid())
  driverId          String
  timeEntryId       String?
  requestedByUserId String?
  updatedByUserId   String?
  reviewedByUserId  String?
  reason            String
  requestedKind     TimeEntryKind?
  requestedOccurredAt DateTime?
  requestedTimezone String?
  requestedGeo      Json?
  requestedNotes    String?
  originalSnapshot  Json?
  requestedSnapshot Json?
  status            TimeAdjustmentStatus @default(PENDING)
  reviewerNote      String?
  reviewedAt        DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  timeEntry TimeEntry? @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)
  requestedByUser User? @relation("TimeAdjustmentRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("TimeAdjustmentUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  reviewedByUser User? @relation("TimeAdjustmentReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([driverId, status, createdAt])
  @@index([timeEntryId])
  @@index([requestedByUserId])
  @@index([updatedByUserId])
  @@index([reviewedByUserId])
  @@index([status, createdAt])
}

model TimeEntryIssue {
  id          String               @id @default(cuid())
  externalKey String               @unique
  driverId    String
  dateKey     String
  code        TimeEntryIssueCode
  severity    TimeEntryIssueSeverity
  status      TimeEntryIssueStatus @default(OPEN)
  message     String
  entryIds    Json
  resolvedAt  DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId, dateKey])
  @@index([status, dateKey])
  @@index([code, dateKey])
}

model TimeSheetDay {
  id                    String   @id @default(cuid())
  driverId              String
  dateKey               String
  workProfileTemplateId String?
  journeyTemplateId     String?
  expectedMinutes       Int      @default(0)
  workedMinutes         Int      @default(0)
  breakMinutes          Int      @default(0)
  latenessMinutes       Int      @default(0)
  earlyLeaveMinutes     Int      @default(0)
  overtimeMinutes       Int      @default(0)
  hasOpenIssues         Boolean  @default(false)
  openIssueCount        Int      @default(0)
  calculationMeta       Json?
  calculatedAt          DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([driverId, dateKey])
  @@index([dateKey])
  @@index([driverId, calculatedAt])
}

model TimeSheetPeriod {
  id                  String   @id @default(cuid())
  driverId            String
  periodKey           String
  expectedMinutes     Int      @default(0)
  workedMinutes       Int      @default(0)
  normalMinutes       Int      @default(0)
  overtimeMinutes     Int      @default(0)
  nightMinutes        Int      @default(0)
  breakMinutes        Int      @default(0)
  latenessMinutes     Int      @default(0)
  earlyLeaveMinutes   Int      @default(0)
  absenceDays         Int      @default(0)
  workedDays          Int      @default(0)
  openIssueDays       Int      @default(0)
  openIssueCount      Int      @default(0)
  status              TimeSheetPeriodStatus @default(OPEN)
  closedAt            DateTime?
  reopenedAt          DateTime?
  closedByUserId      String?
  reopenedByUserId    String?
  lockNote            String?
  rulesSnapshot       Json?
  calculatedAt        DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  events TimeSheetPeriodEvent[]

  @@unique([driverId, periodKey])
  @@index([periodKey])
  @@index([driverId, calculatedAt])
  @@index([status, periodKey])
}

model TimeSheetPeriodEvent {
  id          String @id @default(cuid())
  periodId    String
  action      TimeSheetPeriodEventAction
  actorUserId String?
  note        String?
  createdAt   DateTime @default(now())

  period TimeSheetPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@index([periodId, createdAt])
  @@index([action, createdAt])
}

model Vehicle {
  id        String   @id @default(cuid())
  driverId  String
  label     String
  plate     String
  color     String?
  year      Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driver Driver @relation(fields: [driverId], references: [id])

  @@unique([driverId, plate])
  @@index([driverId, isActive])
}

model DriverLeavePeriod {
  id         String               @id @default(cuid())
  driverId   String
  type       DriverLeavePeriodType
  startDate  DateTime
  endDate    DateTime
  reason     String?
  notes      String?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId, startDate, endDate])
  @@index([type, startDate, endDate])
}

model FleetVehicle {
  id          String             @id @default(cuid())
  label       String
  plate       String             @unique
  checkinCode String             @unique @default(cuid())
  color       String?
  year        Int?
  status      FleetVehicleStatus @default(AVAILABLE)
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  assignments FleetVehicleAssignment[]
  checklistEntries FleetVehicleChecklistEntry[]
  maintenancePlans FleetVehicleMaintenancePlan[]
  maintenanceTasks FleetVehicleMaintenanceTask[]
  odometerLogs FleetVehicleOdometerLog[]
  defaultDrivers Driver[] @relation("DriverDefaultFleetVehicle")

  @@index([status, createdAt])
}

model FleetVehicleAssignment {
  id             String      @id @default(cuid())
  fleetVehicleId String
  driverId       String
  validationMethod FleetVehicleAssignmentValidationMethod @default(ADMIN)
  startedAt      DateTime    @default(now())
  endedAt        DateTime?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  fleetVehicle FleetVehicle @relation(fields: [fleetVehicleId], references: [id])
  driver       Driver       @relation(fields: [driverId], references: [id])

  @@index([fleetVehicleId, endedAt, startedAt])
  @@index([driverId, endedAt, startedAt])
}

model FleetVehicleChecklistEntry {
  id             String   @id @default(cuid())
  fleetVehicleId String
  dateKey        String
  itemKey        String
  templateId     String?
  templateName   String?
  label          String
  description    String?
  category       String?
  routine        FleetChecklistRoutine @default(START_OF_DAY)
  inputType      FleetChecklistInputType @default(BOOLEAN)
  actionType     FleetChecklistTaskActionType @default(NONE)
  sortOrder      Int @default(0)
  isRequired     Boolean @default(true)
  isChecked      Boolean  @default(false)
  numericValue   Int?
  textValue      String?
  selectedOption String?
  checkedAt      DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  fleetVehicle FleetVehicle @relation(fields: [fleetVehicleId], references: [id], onDelete: Cascade)

  @@unique([fleetVehicleId, dateKey, itemKey])
  @@index([fleetVehicleId, dateKey])
}

model FleetChecklistTemplate {
  id        String                 @id @default(cuid())
  name      String
  category  String
  routine   FleetChecklistRoutine  @default(START_OF_DAY)
  isActive  Boolean                @default(true)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  items FleetChecklistTemplateItem[]

  @@index([routine, isActive, createdAt])
}

model FleetChecklistTemplateItem {
  id            String                      @id @default(cuid())
  templateId    String
  itemKey       String                      @unique
  label         String
  description   String?
  inputType     FleetChecklistInputType     @default(BOOLEAN)
  actionType    FleetChecklistTaskActionType @default(NONE)
  selectOptions Json?
  builderConfig Json?
  sortOrder     Int                         @default(0)
  isRequired    Boolean                     @default(true)
  isActive      Boolean                     @default(true)
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  template FleetChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, isActive, sortOrder])
}

model FleetVehicleMaintenancePlan {
  id                   String                       @id @default(cuid())
  fleetVehicleId       String
  title                String
  description          String?
  serviceType          FleetMaintenanceTaskType     @default(PREVENTIVE)
  priority             FleetMaintenanceTaskPriority @default(MEDIUM)
  workshop             String?
  intervalMonths       Int?
  intervalKm           Int?
  firstDueAt           DateTime?
  firstDueKm           Int?
  defaultEstimatedCost Decimal?                     @db.Decimal(10, 2)
  notes                String?
  isActive             Boolean                      @default(true)
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt

  fleetVehicle FleetVehicle @relation(fields: [fleetVehicleId], references: [id], onDelete: Cascade)
  tasks        FleetVehicleMaintenanceTask[]

  @@index([fleetVehicleId, isActive, createdAt])
}

model FleetVehicleMaintenanceTask {
  id                String                      @id @default(cuid())
  fleetVehicleId    String
  maintenancePlanId String?
  title             String
  description       String?
  serviceType       FleetMaintenanceTaskType    @default(GENERAL)
  priority          FleetMaintenanceTaskPriority @default(MEDIUM)
  workshop          String?
  dueAt             DateTime?
  dueKm             Int?
  recurrenceMonths  Int?
  recurrenceKm      Int?
  currentOdometerKm Int?
  estimatedCost     Decimal?                    @db.Decimal(10, 2)
  actualCost        Decimal?                    @db.Decimal(10, 2)
  openedAt          DateTime                    @default(now())
  startedAt         DateTime?
  status            FleetMaintenanceTaskStatus  @default(OPEN)
  completedAt       DateTime?
  notes             String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  fleetVehicle FleetVehicle                 @relation(fields: [fleetVehicleId], references: [id], onDelete: Cascade)
  maintenancePlan FleetVehicleMaintenancePlan? @relation(fields: [maintenancePlanId], references: [id], onDelete: SetNull)

  @@index([fleetVehicleId, status, createdAt])
  @@index([maintenancePlanId, status, createdAt])
}

model FleetVehicleOdometerLog {
  id             String   @id @default(cuid())
  fleetVehicleId String
  odometerKm     Int
  recordedAt     DateTime @default(now())
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  fleetVehicle FleetVehicle @relation(fields: [fleetVehicleId], references: [id], onDelete: Cascade)

  @@index([fleetVehicleId, recordedAt])
}

model Ride {
  id               String     @id @default(cuid())
  customerName     String     @default("Cliente nao informado")
  customerPhone    String
  tripTypeSlug     String?
  tripTypeName     String?
  tripTypeSurchargeAmount Decimal? @db.Decimal(10, 2)
  baggageCount     Int?
  baggageSize      String?
  petType          String?
  petSize          String?
  customerHasReducedMobility Boolean?
  companionNeedsSpecialAttention Boolean?
  companionSpecialAttentionDetails String?
  passengerCount   Int?
  hasIntermediateStops Boolean? 
  intermediateStopsSummary String?
  origin           String
  destination      String
  scheduledAt      DateTime
  status           RideStatus
  quoteAmount      Decimal?   @db.Decimal(10, 2)
  quoteCurrency    String?
  routeDistanceKm  Decimal?   @db.Decimal(10, 2)
  routeDurationMin Int?
  assignedDriverId String?
  driverStage      DriverRideStage?
  pickupCode       String?
  pickupCodeVerifiedAt DateTime?
  navigationStartedAt DateTime?
  arrivedAt        DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  assignedDriver Driver?              @relation("RideAssignedDriver", fields: [assignedDriverId], references: [id])
  quotes         Quote[]
  messages       Message[]
  events         RideEvent[]
  decisions      DriverRideDecision[]
}

model Quote {
  id               String   @id @default(cuid())
  rideId           String
  amount           Decimal  @db.Decimal(10, 2)
  currency         String
  routeDistanceKm  Decimal  @db.Decimal(10, 2)
  routeDurationMin Int
  createdAt        DateTime @default(now())

  ride Ride @relation(fields: [rideId], references: [id])
}

model Message {
  id                String           @id @default(cuid())
  rideId            String?
  customerPhone     String
  direction         MessageDirection
  messageType       MessageType
  content           String?
  providerMessageId String?          @unique
  metadata          Json?
  createdAt         DateTime         @default(now())

  ride Ride? @relation(fields: [rideId], references: [id])
}

model RideEvent {
  id        String   @id @default(cuid())
  rideId    String
  eventType String
  payload   Json?
  createdAt DateTime @default(now())

  ride Ride @relation(fields: [rideId], references: [id])
}

model DriverRideDecision {
  id        String             @id @default(cuid())
  rideId    String
  driverId  String
  decision  DriverDecisionType
  createdAt DateTime           @default(now())

  ride   Ride   @relation(fields: [rideId], references: [id])
  driver Driver @relation(fields: [driverId], references: [id])

  @@index([rideId, driverId])
}

model DriverPushSubscription {
  id        String   @id @default(cuid())
  driverId  String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
}

model DriverExpoPushToken {
  id        String   @id @default(cuid())
  driverId  String
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
}
